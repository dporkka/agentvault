{
  "manifest_version": 3,
  "name": "AgentVault",
  "version": "0.1.0",
  "description": "Clip web pages to your AgentVault knowledge base",
  "permissions": ["activeTab", "storage", "contextMenus"],
  "host_permissions": ["http://127.0.0.1:47321/*"],
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
